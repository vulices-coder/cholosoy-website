generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  date      DateTime
  location  String?
  imageUrl  String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([slug])
}

model GalleryImage {
  id        String   @id @default(uuid())
  url       String
  category  String
  alt       String?
  createdAt DateTime @default(now())

  @@index([category])
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       Float
  category    String
  imageUrl    String?
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([slug])
}

model Reservation {
  id        String            @id @default(cuid())
  name      String
  email     String
  phone     String?
  guests    Int
  dateTime  DateTime
  notes     String?
  locale    String            @default("de")
  status    ReservationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([dateTime])
  @@index([email])
  @@index([status])
  @@index([locale])
}

model CateringRequest {
  id        String         @id @default(cuid())
  name      String
  email     String
  phone     String?
  eventDate DateTime
  location  String?
  people    Int
  budget    Int?
  message   String?
  locale    String         @default("de")
  status    CateringStatus @default(NEW)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([eventDate])
  @@index([email])
  @@index([status])
  @@index([locale])
}

model InfoRequest {
  id        String            @id @default(cuid())
  name      String
  email     String
  reason    String
  message   String
  locale    String            @default("de")
  status    InfoRequestStatus @default(NEW)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([email])
  @@index([status])
  @@index([locale])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum CateringStatus {
  NEW
  CONTACTED
  CONFIRMED
  CANCELED
}

enum InfoRequestStatus {
  NEW
  READ
  ANSWERED
  ARCHIVED
}
